@model bowling_tournament_MVCPRoject.UI.ViewModels.RegisterTeamVm
@{
    ViewData["Title"] = "Register Team for Tournament";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <h3>Register Team for Tournament</h3>

            <div class="card">
            <div class="card-body">
                <form method="post" asp-action="RegisterTeam">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                    <input type="hidden" asp-for="TeamId" />

                    <div class="mb-4">
                        <label asp-for="TournamentId" class="form-label fw-500">Select Tournament</label>
                        <select asp-for="TournamentId" asp-items="Model.TournamentOptions" class="form-select form-select-lg">
                            <option value="">-- Select Tournament --</option>
                        </select>
                        <span asp-validation-for="TournamentId" class="text-danger small d-block mt-2"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success btn-lg flex-grow-1">
                            <i class="bi bi-check-circle"></i> Register
                        </button>
                        <a asp-action="TeamList" asp-controller="Home" class="btn btn-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>