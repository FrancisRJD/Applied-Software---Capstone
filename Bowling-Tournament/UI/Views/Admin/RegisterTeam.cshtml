@model bowling_tournament_MVCPRoject.UI.ViewModels.RegisterTeamVm
@{
    ViewData["Title"] = "Register Team for Tournament";
}
<div class="justify-content-center row">
    <div class="col-6">
        <h3 class="text-center pb-3">Register Team for Tournament</h3>
        <form method="post" asp-action="RegisterTeam">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="TeamId" />
            <div class="mb-3">
                <label asp-for="TournamentId" class="form-label">Tournament</label>
                <select asp-for="TournamentId" asp-items="Model.TournamentOptions" class="form-select">
                    <option value="">-- Select Tournament --</option>
                </select>
            </div>
            <button type="submit" class="btn btn-success w-100">Register</button>
            <a asp-action="TeamListAdmin" class="btn btn-secondary w-100 mt-2">Cancel</a>
        </form>
    </div>
</div>