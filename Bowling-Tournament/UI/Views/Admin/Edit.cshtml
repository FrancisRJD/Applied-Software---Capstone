@model bowling_tournament_MVCPRoject.UI.ViewModels.TeamEditVm
@{
    ViewData["Title"] = "Edit Team";
}
<div class="justify-content-center row">
    <h3 class="text-center pb-3">@Model.TeamName</h3>
    <div class="col-6">
        <form method="post" asp-action="EditTeam">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="TeamId" />
            <div class="row mb-2">
                <label asp-for="TeamName" class="col-4 col-form-label"></label>
                <div class="col-8">
                    <input asp-for="TeamName" class="form-control" />
                    <span asp-validation-for="TeamName" class="text-danger"></span>
                </div>
            </div>
            <div class="row mb-2">
                <label asp-for="DivisionId" class="col-4 col-form-label"></label>
                <div class="col-8">
                    <select asp-for="DivisionId" asp-items="Model.DivisionOptions" class="form-select"></select>
                </div>
            </div>
            <button type="submit" class="btn btn-success w-100 mt-2">Save Team Changes</button>
        </form>

        <h4 class="mt-4">Players</h4>
        @if (Model.Players != null && Model.Players.Any())
        {
            <ul class="list-group mb-3">
                @foreach (var p in Model.Players)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @p.Name
                        <div>
                            <a class="btn btn-warning btn-sm"
                               asp-action="EditPlayer"
                               asp-route-playerId="@p.PlayerId"
                               asp-route-teamId="@Model.TeamId">Edit</a>
                            <form method="post" asp-action="RemovePlayer" class="d-inline">
                                <input type="hidden" name="id" value="@p.PlayerId" />
                                <input type="hidden" name="teamId" value="@Model.TeamId" />
                                <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        }
        @if (Model.Players == null || Model.Players.Count < 4)
        {
            <a asp-action="AddPlayer" asp-route-teamId="@Model.TeamId" class="btn btn-primary w-100">
                Add Player
            </a>
        }
    </div>
</div>