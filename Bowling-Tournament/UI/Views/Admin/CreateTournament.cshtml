@model bowling_tournament_MVCPRoject.UI.ViewModels.TournamentCreateVm
@{
    ViewData["Title"] = "Create Tournament";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h3>Create Tournament</h3>
        
        <div class="card">
            <div class="card-body">
                <form method="post" asp-action="CreateTournament">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-500">Tournament Name</label>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Spring 2025 Championship" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="DateOfGame" class="form-label fw-500">Tournament Date</label>
                                <input asp-for="DateOfGame" class="form-control" type="date" />
                                <span asp-validation-for="DateOfGame" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-500">Location</label>
                        <input asp-for="Location" class="form-control" placeholder="e.g., Downtown Bowling Alley" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />

                    <h5 class="mb-3"><i class="bi bi-people"></i> Overall Capacity</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="TeamCapacity" class="form-label fw-500">Max Teams</label>
                                <input asp-for="TeamCapacity" class="form-control" type="number" min="1" placeholder="Total team limit" />
                                <span asp-validation-for="TeamCapacity" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="WatcherCapacity" class="form-label fw-500">Spectator Capacity</label>
                                <input asp-for="WatcherCapacity" class="form-control" type="number" min="0" placeholder="Spectator limit" />
                                <span asp-validation-for="WatcherCapacity" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h5 class="mb-3"><i class="bi bi-diagram-3"></i> Division Capacities</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="MenCapacity" class="form-label fw-500">Men's Division</label>
                                <input asp-for="MenCapacity" class="form-control" type="number" min="-1" placeholder="-1 for unlimited" />
                                <small class="text-muted">Use -1 for unlimited</small>
                                <span asp-validation-for="MenCapacity" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="WomenCapacity" class="form-label fw-500">Women's Division</label>
                                <input asp-for="WomenCapacity" class="form-control" type="number" min="-1" placeholder="-1 for unlimited" />
                                <small class="text-muted">Use -1 for unlimited</small>
                                <span asp-validation-for="WomenCapacity" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="MixedCapacity" class="form-label fw-500">Mixed Division</label>
                                <input asp-for="MixedCapacity" class="form-control" type="number" min="-1" placeholder="-1 for unlimited" />
                                <small class="text-muted">Use -1 for unlimited</small>
                                <span asp-validation-for="MixedCapacity" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label asp-for="YouthCapacity" class="form-label fw-500">Youth Division</label>
                                <input asp-for="YouthCapacity" class="form-control" type="number" min="-1" placeholder="-1 for unlimited" />
                                <small class="text-muted">Use -1 for unlimited</small>
                                <span asp-validation-for="YouthCapacity" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SeniorCapacity" class="form-label fw-500">Senior Division</label>
                        <input asp-for="SeniorCapacity" class="form-control" type="number" min="-1" placeholder="-1 for unlimited" />
                        <small class="text-muted">Use -1 for unlimited</small>
                        <span asp-validation-for="SeniorCapacity" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="RegistrationOpen" class="form-check-input" type="checkbox" />
                            <label asp-for="RegistrationOpen" class="form-check-label fw-500">
                                <i class="bi bi-unlock-fill"></i> Allow Team Registration
                            </label>
                            <small class="text-muted d-block mt-1">Teams will be able to register for this tournament</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success flex-grow-1">
                            <i class="bi bi-plus-circle"></i> Create Tournament
                        </button>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
