@{
}
@using bowling_tournament_MVCPRoject.UI.ViewModels
@model IEnumerable<TeamDisplayVM>

<div class="text-center justify-content-center row">
    <h3>The NBCC Bowling League</h3>

    <p><a class="btn-primary btn" asp-controller="Home" asp-action="TeamList">Return To Public Listing</a></p>
    <p><a class="btn-primary btn" asp-controller="Admin" asp-action="Summary">View Summary</a></p>

    <div class="container d-flex justify-content-center mt-3">
        <div class="p-3 border rounded bg-light" style="max-width: 650px;">
            <form class="row g-2" method="get" asp-action="TeamListAdmin">

                <!-- Left Side -->
                <div class="col-6">
                    <label class="form-label mb-1 fw-semibold">Filter By</label>
                    <div class="d-flex gap-2">

                        <select class="form-select form-select-sm w-auto" id="filterBy" name="filterBy">
                            <option value="Division">Division</option>
                            <option value="PaymentStatus">Payment Status</option>
                        </select>

                        <select class="form-select form-select-sm w-auto" id="divisionFilter" name="division">
                            <option value="">-- Select --</option>
                            <option value="1">Men's</option>
                            <option value="2">Women's</option>
                            <option value="3">Mixed</option>
                            <option value="4">Youth</option>
                            <option value="5">Senior</option>
                        </select>

                        <select class="form-select form-select-sm w-auto d-none" id="paymentFilter" name="paid">
                            <option value="">-- Select --</option>
                            <option value="true">Paid</option>
                            <option value="false">Unpaid</option>
                        </select>
                    </div>
                </div>

                <!-- Right Side -->
                <div class="col-6">
                    <label class="form-label mb-1 fw-semibold">Sort By</label>
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm w-auto" name="sortBy">
                            <option value="Name">Name</option>
                            <option value="PaymentStatus">Payment Status</option>
                            <option value="PaymentDate">Payment Date</option>
                        </select>

                        <select class="form-select form-select-sm w-auto" name="order">
                            <option value="asc">Ascending</option>
                            <option value="desc">Descending</option>
                        </select>
                    </div>
                </div>

                <div>
                    <button type="submit" class="btn btn-primary">Filter</button>
                </div>

            </form>

        </div>
    </div>

    <div>
        @foreach (var division in Model.GroupBy(division => division.TeamDivision))
        {
            <h4 class="align-middle">@division.Key</h4>
            <table class="table table-responsive">
                <thead>
                    <tr>
                        <th>Team</th>
                        <th>Paid Fee</th>
                        <th>Payment Date</th>
                        <th></th> @*2nd row is for admin-only buttons!*@
                    </tr>
                </thead>
                <tbody>
                    @foreach (var team in Model.Where(t => t.TeamDivision == division.Key))
                    {
                        <tr>
                            <td>@team.TeamName</td>
                            <td>@team.IsPaid</td>
                            <td>@team.DatePaid</td>
                            <td>
                                <a class="btn-primary btn" asp-controller="Home" asp-action="Details" asp-route-id="@team.TeamId"><i class="bi bi-search"></i> View</a>
                                <a class="btn-primary btn" asp-action="EditTeam" asp-route-id="@team.TeamId"><i class="bi bi-pencil" aria-hidden="true"></i> Edit</a>
                                <a class="btn-primary btn" asp-action="DeleteTeam" asp-route-id="@team.TeamId"><i class="bi bi-trash" aria-hidden="true"></i> Delete</a>
                                @if (team.IsPaid)
                                {
                                    <a class="btn-primary btn disabled"><i class="bi bi-calendar-check"></i> Mark Paid</a>
                                }
                                else
                                {
                                    <a class="btn-primary btn" asp-action="MarkPaid" asp-route-id="@team.TeamId"><i class="bi bi-calendar-check"></i> Mark Paid</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
