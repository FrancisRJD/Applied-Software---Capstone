@using bowling_tournament_MVCPRoject.Domain.Entities
@model List<bowling_tournament_MVCPRoject.UI.ReadModels.RegistrationListItem>
@{
    ViewData["Title"] = "Registration List - Admin View";
}
<div class="text-center justify-content-center row">
    <h3>The NBCC Bowling League</h3>
    <p><a class="btn-primary btn" asp-controller="Home" asp-action="TeamList">Return To Public Team Listing</a></p>
    <p><a class="btn-primary btn" asp-controller="Admin" asp-action="Summary">View Summary</a></p>
    <div class="container d-flex justify-content-center mt-3">
        <div class="p-3 border rounded bg-light" style="max-width: 650px;">
            <form class="row g-2" method="get" asp-action="TeamRegistrationAdmin">
                <div class="col-6">
                    <label class="form-label mb-1 fw-semibold">Filter By</label>
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm w-auto" id="filterBy" name="filterBy">
                            <option value="Division">Division</option>
                            <option value="PaymentStatus">Payment Status</option>
                        </select>
                        <select class="form-select form-select-sm w-auto" id="divisionFilter" name="division">
                            <option value="">-- Select --</option>
                            <option value="1">Division 1</option>
                            <option value="2">Division 2</option>
                            <option value="3">Division 3</option>
                            <option value="4">Division 4</option>
                            <option value="5">Division 5</option>
                        </select>
                        <select class="form-select form-select-sm w-auto d-none" id="paymentFilter" name="paid">
                            <option value="">-- Select --</option>
                            <option value="true">Paid</option>
                            <option value="false">Unpaid</option>
                        </select>
                    </div>
                </div>
                <div class="col-6">
                    <label class="form-label mb-1 fw-semibold">Sort By</label>
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm w-auto" name="sortBy">
                            <option value="Name">Name</option>
                            <option value="PaymentStatus">Payment Status</option>
                            <option value="PaymentDate">Payment Date</option>
                        </select>
                        <select class="form-select form-select-sm w-auto" name="order">
                            <option value="asc">Ascending</option>
                            <option value="desc">Descending</option>
                        </select>
                    </div>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary">Filter</button>
                </div>
            </form>
        </div>
    </div>
    <div>
        @foreach (var division in Model.GroupBy(t => t.team.divisionName))
        {
            <h4 class="align-middle">@division.Key</h4>
            <table class="table table-responsive">
                <thead>
                    <tr>
                        <th>Tournament</th>
                        <th>Team</th>
                        <th>Status</th>
                        <th>Status Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var registration in division)
                    {
                        <tr>
                            <td>@registration.tournament.tournamentName</td>
                            <td>@registration.team.teamName</td>
                            @switch (registration.registrationStatus)
                            {
                                case RegistrationStatus.OnHold:
                                    <td>Paid, On Hold</td>
                                    break;
                                case RegistrationStatus.Registered:
                                    <td>Paid, Registered</td>
                                    break;
                                default:
                                    <td>(CASE MISSING FOR STATUS @registration.registrationStatus.ToString() )</td>
                                    break;
                            }
                            <td>
                                @registration.statusDate
                            </td>
                            <td>
                                <a class="btn-primary btn" asp-action="DetailsAdmin" asp-route-id="@registration.team.id"><i class="bi bi-search"></i> View Team</a>
                            @* Not yet strictly required by sprint 1B, I leave implementation of registration 
                                deletion this early up to your discretion
                                <a class="btn-primary btn" asp-action="DeleteRegistration" asp-route-id="@registration.id"><i class="bi bi-trash"></i> Delete</a>
                            *@
                            @* MOVED TO NEW TEAMLISTADMIN FILE
                                <a class="btn-primary btn" asp-action="EditTeam" asp-route-id="@registration.team.id"><i class="bi bi-pencil"></i> Edit</a>
                                <a class="btn-primary btn" asp-action="DeleteTeam" asp-route-id="@registration.team.id"><i class="bi bi-trash"></i> Delete</a>
                                <a class="btn-primary btn" asp-action="RegisterTeam" asp-route-teamId="@registration.id"><i class="bi bi-trophy"></i>Register</a> 
                                @if (registration.registrationStatus == RegistrationStatus.Paid)
                                {
                                    <a class="btn-primary btn disabled"><i class="bi bi-calendar-check"></i> Mark Paid</a>
                                }
                                else
                                {
                                    <a class="btn-primary btn" asp-action="MarkPaid" asp-route-teamId="@registration.id">
                                        <i class="bi bi-calendar-check"></i> Mark Paid
                                    </a>
                                }

                                *@
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>