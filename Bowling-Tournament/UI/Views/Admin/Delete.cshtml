@model bowling_tournament_MVCPRoject.UI.ReadModels.TeamListItem
@{
    ViewData["Title"] = "Delete Team";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h3>Delete Team</h3>

        <div class="card border-danger mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">@Model.teamName</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Division:</dt>
                    <dd class="col-sm-9">@Model.divisionName</dd>

                    <dt class="col-sm-3">Payment Status:</dt>
                    <dd class="col-sm-9">
                        @if (Model.isPaid)
                        {
                            <span class="status-badge status-paid">
                                <i class="bi bi-check-circle-fill"></i> Paid
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-unpaid">
                                <i class="bi bi-exclamation-circle-fill"></i> Unpaid
                            </span>
                        }
                    </dd>

                    <dt class="col-sm-3">Players:</dt>
                    <dd class="col-sm-9">
                        <ul class="list-unstyled">
                            @foreach (var player in Model.Players)
                            {
                                <li>@player.Name</li>
                            }
                        </ul>
                    </dd>
                </dl>
            </div>
        </div>

        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Warning:</strong> This action cannot be undone. The team and all associated player data will be permanently deleted.
        </div>

        <div class="text-center">
            <h5 class="mb-4">Are you sure you want to delete this team?</h5>
            <form asp-action="DeleteTeamConfirmed" method="post">
                <input type="hidden" name="id" value="@Model.id" />
                <div class="d-flex gap-2 justify-content-center">
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="bi bi-trash"></i> Confirm Deletion
                    </button>
                    <a asp-action="TeamList" asp-controller="Home" class="btn btn-secondary btn-lg">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
