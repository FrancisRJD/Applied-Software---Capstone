@model bowling_tournament_MVCPRoject.UI.ReadModels.TeamListItem
@{
    ViewData["Title"] = "Delete Team";
}
<div class="justify-content-center row">
    <div class="col-10">
        <div class="card">
            <div class="card-header">
                <h3>@Model.teamName</h3>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li>Division: @Model.divisionName</li>
                    <li>Paid: @(Model.isPaid
                        ? "Yes" : "No")</li>
                    <li>
                        <h4 class="pt-2">Players:</h4>
                        <ul class="list-group list-unstyled">
                            @foreach (var player in Model.Players)
                            {
                                <li>@player.Name</li>
                            }
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    <div class="text-center mt-3">
        <h3>Are you sure you want to delete this team?</h3>
        <form asp-action="DeleteTeamConfirmed" method="post">
            <input type="hidden" name="id" value="@Model.id" />
            <button type="submit" class="w-25 btn btn-danger">Confirm Deletion</button>
            <a asp-action="TeamListAdmin" class="w-25 btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>