@model bowling_tournament_MVCPRoject.UI.ViewModels.TeamCreateVm

@{
	ViewData["Title"] = "Create Team";
}

<div class="container mt-4">
	<div class="row justify-content-center">
		<div class="col-md-6">
			<h3 class="mb-4">Team Registration</h3>

			<form asp-action="Register" method="post">

				<div asp-validation-summary="All" class="text-danger mb-3"></div>

				<div class="form-group mb-3">
					<label asp-for="TeamName" class="form-label">Team Name:</label>
					<input asp-for="TeamName" class="form-control" />
					<span asp-validation-for="TeamName" class="text-danger"></span>
				</div>

				<div class="form-group mb-3">
					<label asp-for="DivisionOptions" class="form-label">Division:</label>
					<select asp-for="DivisionOptions" asp-items="Model.DivisionOptions" class="form-select"></select>
					<span asp-validation-for="DivisionOptions" class="text-danger"></span>
				</div>

				<div class="form-group mb-3">
					<label asp-for="PlayerOptions" class="form-label">Players:</label>
					<select asp-for="PlayerOptions" asp-items="Model.PlayerOptions" class="form-select"></select>
					<span asp-validation-for="PlayerOptions" class="text-danger"></span>
				</div>

				<button type="submit" class="btn btn-success">
					Submit Team Registration
				</button>

			</form>
		</div>
	</div>
</div>
