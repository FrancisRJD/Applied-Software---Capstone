@model bowling_tournament_MVCPRoject.UI.ViewModels.TeamRegisterVm
@{
    ViewData["Title"] = "Register Team";
}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h3 class="mb-4">Team Registration</h3>
            <form asp-controller="Team" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="TeamName" class="form-label">Team Name</label>
                    <input asp-for="TeamName" class="form-control" />
                    <span asp-validation-for="TeamName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="DivisionId" class="form-label">Division</label>
                    <select asp-for="DivisionId" asp-items="Model.DivisionOptions" class="form-select">
                        <option value="">-- Select Division --</option>
                    </select>
                    <span asp-validation-for="DivisionId" class="text-danger"></span>
                </div>

                <h4 class="mt-4 mb-3">Players</h4>
                @for (int i = 0; i < Model.Players.Count; i++)
                {
                    <div class="card mb-3">
                        <div class="card-header">Player @(i + 1)</div>
                        <div class="card-body">
                            <div class="mb-2">
                                <label class="form-label">Name</label>
                                <input asp-for="Players[i].PlayerName" class="form-control" />
                                <span asp-validation-for="Players[i].PlayerName" class="text-danger"></span>
                            </div>
                            <div class="mb-2">
                                <label class="form-label">City</label>
                                <input asp-for="Players[i].City" class="form-control" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Province</label>
                                <input asp-for="Players[i].Province" class="form-control" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Email</label>
                                <input asp-for="Players[i].Email" class="form-control" />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Phone</label>
                                <input asp-for="Players[i].Phone" class="form-control" />
                            </div>
                        </div>
                    </div>
                }

                <button type="submit" class="btn btn-success w-100">Submit Team Registration</button>
            </form>
        </div>
    </div>
</div>